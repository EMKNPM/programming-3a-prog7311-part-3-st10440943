@model GLMS.Web.Models.Contract
@{
    ViewData["Title"] = "Delete Contract";
}

<div class="page-header">
    <h2 class="page-title">Delete Contract</h2>
    <p class="page-subtitle">This action cannot be undone</p>
</div>

<div class="glms-form-card">
    <div class="glms-alert glms-alert-danger mb-4">
        ⚠️ Are you sure you want to delete this contract and all its service requests?
    </div>
    <table class="table glms-table mb-4">
        <tr><th>Client</th><td>@Model.Client?.Name</td></tr>
        <tr><th>Service Level</th><td>@Model.ServiceLevel</td></tr>
        <tr><th>Start Date</th><td>@Model.StartDate.ToString("dd MMM yyyy")</td></tr>
        <tr><th>End Date</th><td>@Model.EndDate.ToString("dd MMM yyyy")</td></tr>
        <tr>
            <th>Status</th>
            <td>
                <span class="status-badge status-@Model.Status.ToString().ToLower()">
                    @Model.Status
                </span>
            </td>
        </tr>
    </table>
    <form asp-action="Delete" method="post">
        <input type="hidden" asp-for="Id" />
        <div class="d-flex gap-2">
            <button type="submit" class="btn-danger-custom">Yes, Delete</button>
            <a asp-action="Index" class="btn-warning-custom">Cancel</a>
        </div>
    </form>
</div>