@model GLMS.Web.Models.Contract
@{
    ViewData["Title"] = "Contract Details";
}

<div class="page-header d-flex justify-content-between align-items-center">
    <div>
        <h2 class="page-title">Contract Details</h2>
        <p class="page-subtitle">Full details for this logistics agreement</p>
    </div>
    <div class="d-flex gap-2">
        <a asp-action="Edit" asp-route-id="@Model.Id" class="btn-warning-custom">Edit</a>
        <a asp-action="Index" class="btn-info-custom">← Back to Contracts</a>
    </div>
</div>

<!-- Contract Info Card -->
<div class="glms-card mb-4">
    <div class="glms-card-header">
        <span class="glms-card-title">📄 Contract Information</span>
        <span class="status-badge status-@Model.Status.ToString().ToLower()">@Model.Status</span>
    </div>
    <div class="row g-3">
        <div class="col-md-6">
            <div class="mb-3">
                <label class="form-label">Client</label>
                <div class="form-control" style="cursor:default">@Model.Client?.Name</div>
            </div>
            <div class="mb-3">
                <label class="form-label">Region</label>
                <div class="form-control" style="cursor:default">@Model.Client?.Region</div>
            </div>
            <div class="mb-3">
                <label class="form-label">Service Level</label>
                <div class="form-control" style="cursor:default">@Model.ServiceLevel</div>
            </div>
        </div>
        <div class="col-md-6">
            <div class="mb-3">
                <label class="form-label">Start Date</label>
                <div class="form-control" style="cursor:default">@Model.StartDate.ToString("dd MMM yyyy")</div>
            </div>
            <div class="mb-3">
                <label class="form-label">End Date</label>
                <div class="form-control" style="cursor:default">@Model.EndDate.ToString("dd MMM yyyy")</div>
            </div>
            <div class="mb-3">
                <label class="form-label">Status</label>
                <div class="form-control" style="cursor:default">@Model.Status</div>
            </div>
        </div>
    </div>

    <!-- Signed Agreement -->
    <div class="mt-2">
        <label class="form-label">Signed Agreement</label>
        <div>
            @if (!string.IsNullOrEmpty(Model.SignedAgreementPath))
            {
                <a asp-controller="Contracts" asp-action="Download"
                   asp-route-filePath="@Model.SignedAgreementPath"
                   class="btn-primary-custom">
                    ⬇ Download PDF Agreement
                </a>
            }
            else
            {
                <span style="color:var(--text-muted)">No signed agreement uploaded</span>
            }
        </div>
    </div>
</div>

<!-- Service Requests Linked to This Contract -->
<div class="glms-card">
    <div class="glms-card-header">
        <span class="glms-card-title">📋 Linked Service Requests</span>
        <span style="color:var(--text-muted);font-size:0.85rem">
            @Model.ServiceRequests.Count request(s)
        </span>
    </div>

    @if (!Model.ServiceRequests.Any())
    {
        <div class="empty-state" style="padding:2rem">
            <div class="empty-icon">📋</div>
            <h4>No Service Requests</h4>
            <p>No service requests have been raised against this contract yet.</p>
            @if (Model.Status == GLMS.Web.Models.ContractStatus.Active)
            {
                <a asp-controller="ServiceRequests" asp-action="Create"
                   class="btn-primary-custom mt-2">+ New Service Request</a>
            }
        </div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table glms-table">
                <thead>
                    <tr>
                        <th>Description</th>
                        <th>Cost (USD)</th>
                        <th>Cost (ZAR)</th>
                        <th>Rate Used</th>
                        <th>Status</th>
                        <th>Created</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var sr in Model.ServiceRequests)
                    {
                        <tr>
                            <td>@sr.Description</td>
                            <td style="color:var(--green-primary);font-weight:600">
                                $@sr.CostUSD.ToString("N2")
                            </td>
                            <td style="font-weight:600">R @sr.CostZAR.ToString("N2")</td>
                            <td><small style="color:var(--text-muted)">@sr.ExchangeRateUsed</small></td>
                            <td>
                                <span class="status-badge status-@sr.Status.ToString().ToLower()">
                                    @sr.Status
                                </span>
                            </td>
                            <td><small>@sr.CreatedDate.ToString("dd MMM yyyy")</small></td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <!-- Totals Row -->
        <div class="mt-3 pt-3" style="border-top:1px solid var(--border-color)">
            <div class="d-flex gap-4">
                <div>
                    <span style="color:var(--text-muted);font-size:0.8rem">TOTAL USD</span>
                    <div style="color:var(--green-primary);font-weight:700;font-size:1.1rem">
                        $@Model.ServiceRequests.Sum(sr => sr.CostUSD).ToString("N2")
                    </div>
                </div>
                <div>
                    <span style="color:var(--text-muted);font-size:0.8rem">TOTAL ZAR</span>
                    <div style="color:var(--text-primary);font-weight:700;font-size:1.1rem">
                        R @Model.ServiceRequests.Sum(sr => sr.CostZAR).ToString("N2")
                    </div>
                </div>
            </div>
        </div>
    }
</div>