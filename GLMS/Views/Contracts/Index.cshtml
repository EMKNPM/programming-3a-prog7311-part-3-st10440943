@model IEnumerable<GLMS.Web.Models.Contract>
@{
    ViewData["Title"] = "Contracts";
}

<div class="page-header d-flex justify-content-between align-items-center">
    <div>
        <h2 class="page-title">Contract Hub</h2>
        <p class="page-subtitle">Search, filter and manage all logistics contracts</p>
    </div>
    <a asp-action="Create" class="btn-primary-custom">+ New Contract</a>
</div>

<form method="get" class="filter-bar">
    <div>
        <label class="form-label">Start Date</label>
        <input type="date" name="startDate" class="form-control" value="@ViewBag.StartDate" />
    </div>
    <div>
        <label class="form-label">End Date</label>
        <input type="date" name="endDate" class="form-control" value="@ViewBag.EndDate" />
    </div>
    <div>
        <label class="form-label">Status</label>
        <select name="status" class="form-select" style="min-width:140px">
            <option value="">All Statuses</option>
            @foreach (var s in ViewBag.Statuses)
            {
                <option value="@s" selected="@(ViewBag.Status?.ToString() == s.ToString())">@s</option>
            }
        </select>
    </div>
    <div>
        <button type="submit" class="btn-primary-custom">🔍 Filter</button>
    </div>
</form>

@if (!Model.Any())
{
    <div class="empty-state">
        <div class="empty-icon">📄</div>
        <h4>No Contracts Found</h4>
        <p>Try adjusting your filters or create a new contract.</p>
    </div>
}
else
{
    <div class="glms-card">
        <div class="table-responsive">
            <table class="table glms-table">
                <thead>
                    <tr>
                        <th>Client</th>
                        <th>Start</th>
                        <th>End</th>
                        <th>Status</th>
                        <th>SLA</th>
                        <th>Agreement</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var c in Model)
                    {
                        <tr>
                            <td class="fw-semibold">@c.Client?.Name</td>
                            <td>@c.StartDate.ToString("dd MMM yyyy")</td>
                            <td>@c.EndDate.ToString("dd MMM yyyy")</td>
                            <td>
                                <span class="status-badge status-@c.Status.ToString().ToLower()">@c.Status</span>
                            </td>
                            <td>@c.ServiceLevel</td>
                            <td>
                                @if (!string.IsNullOrEmpty(c.SignedAgreementPath))
                                {
                                    <a asp-action="Download" asp-route-filePath="@c.SignedAgreementPath" class="btn-info-custom">⬇ PDF</a>
                                }
                                else
                                {

                                    <span style="color:var(--text-muted)">None</span>
                                }
                            </td>
                            <td class="d-flex gap-2">
                                <a asp-action="Details" asp-route-id="@c.Id" class="btn-info-custom">Details</a>
                                <a asp-action="Edit" asp-route-id="@c.Id" class="btn-warning-custom">Edit</a>
                                <a asp-action="Delete" asp-route-id="@c.Id" class="btn-danger-custom">Delete</a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}