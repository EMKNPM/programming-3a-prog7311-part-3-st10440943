@model GLMS.Web.Models.Client
@{
    ViewData["Title"] = "Edit Client";
}

<div class="page-header">
    <h2 class="page-title">Edit Client</h2>
    <p class="page-subtitle">Update client profile</p>
</div>

<div class="glms-form-card">
    <form asp-action="Edit" method="post">
        <input type="hidden" asp-for="Id" />
        <div class="mb-3">
            <label asp-for="Name" class="form-label"></label>
            <input asp-for="Name" class="form-control" />
            <span asp-validation-for="Name" class="text-danger"></span>
        </div>
        <div class="mb-3">
            <label asp-for="Email" class="form-label"></label>
            <input asp-for="Email" class="form-control" />
            <span asp-validation-for="Email" class="text-danger"></span>
        </div>
        <div class="mb-3">
            <label asp-for="Phone" class="form-label"></label>
            <input asp-for="Phone" class="form-control" />
        </div>
        <div class="mb-3">
            <label asp-for="Region" class="form-label"></label>
            <input asp-for="Region" class="form-control" />
        </div>
        <div class="d-flex gap-2 mt-4">
            <button type="submit" class="btn-primary-custom">Save Changes</button>
            <a asp-action="Index" class="btn-warning-custom">Cancel</a>
        </div>
    </form>
</div>