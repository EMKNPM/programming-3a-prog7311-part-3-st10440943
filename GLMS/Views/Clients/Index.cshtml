@model IEnumerable<GLMS.Web.Models.Client>
@{
    ViewData["Title"] = "Clients";
}

<div class="page-header d-flex justify-content-between align-items-center">
    <div>
        <h2 class="page-title">Clients</h2>
        <p class="page-subtitle">Manage all TechMove client profiles</p>
    </div>
    <a asp-action="Create" class="btn-primary-custom">+ Add Client</a>
</div>

@if (!Model.Any())
{
    <div class="empty-state">
        <div class="empty-icon">🏢</div>
        <h4>No Clients Yet</h4>
        <p>Add your first client to get started.</p>
        <a asp-action="Create" class="btn-primary-custom mt-2">+ Add Client</a>
    </div>
}
else
{
    <div class="glms-card">
        <div class="table-responsive">
            <table class="table glms-table">
                <thead>
                    <tr>
                        <th>Name</th>
                        <th>Email</th>
                        <th>Phone</th>
                        <th>Region</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var c in Model)
                    {
                        <tr>
                            <td class="fw-semibold">@c.Name</td>
                            <td>@c.Email</td>
                            <td>@c.Phone</td>
                            <td><span class="status-badge status-active">@c.Region</span></td>
                            <td class="d-flex gap-2">
                                <a asp-action="Edit" asp-route-id="@c.Id" class="btn-warning-custom">Edit</a>
                                <a asp-action="Delete" asp-route-id="@c.Id" class="btn-danger-custom">Delete</a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}