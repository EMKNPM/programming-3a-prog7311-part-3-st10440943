@model GLMS.Web.Models.Client
@{
    ViewData["Title"] = "Delete Client";
}

<div class="page-header">
    <h2 class="page-title">Delete Client</h2>
    <p class="page-subtitle">This action cannot be undone</p>
</div>

<div class="glms-form-card">
    <div class="glms-alert glms-alert-danger mb-4">
        ⚠️ Are you sure you want to delete this client?
    </div>
    <table class="table glms-table mb-4">
        <tr><th>Name</th><td>@Model.Name</td></tr>
        <tr><th>Email</th><td>@Model.Email</td></tr>
        <tr><th>Phone</th><td>@Model.Phone</td></tr>
        <tr><th>Region</th><td>@Model.Region</td></tr>
    </table>
    <form asp-action="Delete" method="post">
        <input type="hidden" asp-for="Id" />
        <div class="d-flex gap-2">
            <button type="submit" class="btn-danger-custom">Yes, Delete</button>
            <a asp-action="Index" class="btn-warning-custom">Cancel</a>
        </div>
    </form>
</div>