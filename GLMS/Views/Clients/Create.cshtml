@model GLMS.Web.Models.Client
@{
    ViewData["Title"] = "Add Client";
}

<div class="page-header">
    <h2 class="page-title">Add New Client</h2>
    <p class="page-subtitle">Register a new TechMove client profile</p>
</div>

<div class="glms-form-card">
    <form asp-action="Create" method="post">
        <div class="mb-3">
            <label asp-for="Name" class="form-label"></label>
            <input asp-for="Name" class="form-control" placeholder="e.g. Acme Freight Ltd" />
            <span asp-validation-for="Name" class="text-danger"></span>
        </div>
        <div class="mb-3">
            <label asp-for="Email" class="form-label"></label>
            <input asp-for="Email" class="form-control" placeholder="contact@company.com" />
            <span asp-validation-for="Email" class="text-danger"></span>
        </div>
        <div class="mb-3">
            <label asp-for="Phone" class="form-label"></label>
            <input asp-for="Phone" class="form-control" placeholder="+27 11 000 0000" />
        </div>
        <div class="mb-3">
            <label asp-for="Region" class="form-label"></label>
            <input asp-for="Region" class="form-control" placeholder="e.g. Africa, Europe, Asia" />
        </div>
        <div class="d-flex gap-2 mt-4">
            <button type="submit" class="btn-primary-custom">Save Client</button>
            <a asp-action="Index" class="btn-warning-custom">Cancel</a>
        </div>
    </form>
</div>